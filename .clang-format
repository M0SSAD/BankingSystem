BasedOnStyle: LLVM
Language: Cpp
Standard: c++17

# Indentation
IndentWidth: 4
TabWidth: 4
UseTab: Never

# Line Constraints
ColumnLimit: 100

# Modern C++ Pointer/Reference Alignment (int* ptr, not int *ptr)
PointerAlignment: Left
ReferenceAlignment: Left

# Braces and Spacing
BreakBeforeBraces: Attach
AllowShortFunctionsOnASingleLine: Empty
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: Never

# Include Sorting (Forces alphabetical sorting to prevent hidden dependencies)
SortIncludes: true